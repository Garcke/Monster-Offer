# Text model selection. Leave commented to use active_profile from
# server/config/default_model_profiles.json.
# LLM_ACTIVE_PROFILE=openrouter

# Required to read or write encrypted mutable profiles. Set a URL-safe base64
# Fernet key outside version control; the application never generates one.
MODEL_CONFIG_MASTER_KEY=
# Optional override. Defaults to cache/model_profiles.json.
MODEL_PROFILE_STORE_PATH=

# Required for Electron model-management requests. Use a long random value and
# expose management endpoints only through a protected HTTPS deployment.
APP_ADMIN_TOKEN=

# API keys used by the built-in model profiles. Fill only the active provider.
OPENROUTER_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
ANTHROPIC_COMPATIBLE_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
KILOCODE_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
OPENCODE_ZEN_API_KEY=
OPENCODE_GO_API_KEY=

# Optional local ASR tuning
LOCAL_ASR_MODEL_DIR=
LOCAL_ASR_NUM_THREADS=2
LOCAL_ASR_RULE1_MIN_TRAILING_SILENCE=2.4
LOCAL_ASR_RULE2_MIN_TRAILING_SILENCE=0.8
LOCAL_ASR_RULE3_MIN_UTTERANCE_LENGTH=20.0
