{
  "name": "meeting-monster-desktop",
  "version": "2.2.1",
  "private": true,
  "description": "Meeting-Monster Windows privacy desktop shell",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build && electron .",
    "check": "npm run typecheck",
    "dist": "npm run dist:win",
    "dist:win": "electron-builder --win nsis portable",
    "dist:win:unsigned": "electron-builder --win nsis portable -c.win.signAndEditExecutable=false -c.forceCodeSigning=false",
    "dist:mac": "electron-builder --mac dmg zip --universal",
    "dist:mac:unsigned": "electron-builder --mac dmg zip --universal -c.mac.identity=null -c.mac.hardenedRuntime=false -c.mac.notarize=false -c.forceCodeSigning=false"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "electron": "37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.garcke.meetingmonster",
    "productName": "Meeting-Monster",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!debug.log"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Meeting-Monster-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Meeting-Monster-Portable-${version}.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "Meeting-Monster-Mac-Universal-${version}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ]
    }
  }
}
